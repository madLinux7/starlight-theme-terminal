{
  "name": "starlight-theme-terminal",
  "version": "0.0.1",
  "license": "MIT",
  "description": "A customized Astro Starlight theme combining modern and retro elements.",
  "author": "madLinux7",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "keywords": [
    "starlight",
    "theme",
    "terminal",
    "plugin",
    "documentation",
    "astro"
  ],
  "packageManager": "pnpm@10.26.0",
  "private": true,
  "sideEffects": false,
  "scripts": {
    "start:docs": "pnpm -F starlight-theme-terminal-docs dev",
    "build:docs": "pnpm -F starlight-theme-terminal-docs build",
    "lint": "astro check --noSync && pnpm -r lint",
    "ci-version": "changeset version && pnpm install --no-frozen-lockfile",
    "ci-publish": "changeset publish"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.5.0",
    "astro": "^6.0.8",
    "eslint": "^10.1.0"
  },
  "homepage": "https://github.com/madLinux7/starlight-theme-terminal",
  "repository": {
    "type": "git",
    "url": "https://github.com/madLinux7/starlight-theme-terminal.git"
  },
  "bugs": "https://github.com/madLinux7/starlight-theme-terminal/issues"
}
