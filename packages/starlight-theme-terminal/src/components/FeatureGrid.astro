---
interface Props {
  columns?: 2 | 3 | 4;
  minWidth?: string;
  gap?: string;
}

const { columns = 2, minWidth = '16rem', gap = '1.5rem' } = Astro.props;
---

<div class="feature-grid" data-columns={columns} style={`--fg-min: ${minWidth}; --fg-gap: ${gap};`}>
  <slot />
</div>

<style>
  .feature-grid {
    display: grid;
    gap: var(--fg-gap);
    margin: 2rem 0;
    grid-template-columns: repeat(var(--fg-cols, 2), minmax(0, 1fr));
  }

  .feature-grid[data-columns="2"] { --fg-cols: 2; }
  .feature-grid[data-columns="3"] { --fg-cols: 3; }
  .feature-grid[data-columns="4"] { --fg-cols: 4; }

  .feature-grid > :global(article) {
    margin-top: 0 !important;
  }

  .feature-grid > :global(.sl-link-card) {
    margin-top: 0 !important;
  }

  .feature-grid :global(.card .title > span) {
    font-weight: 600;
    font-size: 1.1rem;
    background: var(--terminal-title-gradient) !important;
    -webkit-background-clip: text !important;
    background-clip: text !important;
    -webkit-text-fill-color: transparent !important;
  }

  @media (max-width: 60rem) {
    .feature-grid[data-columns="4"],
    .feature-grid[data-columns="3"] {
      --fg-cols: 2;
    }
  }

  @media (max-width: 48rem) {
    .feature-grid[data-columns="2"],
    .feature-grid[data-columns="3"],
    .feature-grid[data-columns="4"] {
      --fg-cols: 1;
      gap: 1rem;
      margin: 1.5rem 0;
    }
  }
</style>
